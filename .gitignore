# Go project gitignore

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go build artifacts
/bin/
/dist/

# Go test artifacts
coverage.txt
coverage.html
coverage.out

# Vendor directory (if used)
vendor/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Environment files (security)
.env
.env.*
!.env.example

# ignore mcp.json
mcp.json
.mcp.json

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
tmp/

# Test containers
.testcontainers/

# MCP SDK generated files
*.generated.go

# Claude Code local settings
.claude/settings.local.json
.claude/plans/
.claude/tasks/
.claude/teams/
.claude/skills/

# SpecKit directories
specs/
.specify/

# Integration test output
integration_output.txt
test_output.txt